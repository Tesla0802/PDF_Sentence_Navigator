{
  "manifest_version": 3,
  "name": "PDF Sentence Navigator",
  "version": "1.0.0",
  "description": "PDF დოკუმენტში წინადადებებზე გადაადგილება TAB / SHIFT+TAB კლავიშებით.",
  "key": "",

  "permissions": ["declarativeNetRequest", "storage"],
  "host_permissions": ["<all_urls>"],

  "action": {
    "default_title": "PDF Sentence Navigator",
    "default_popup": "popup.html"
  },

  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },

  "web_accessible_resources": [
    {
      "resources": ["viewer.html", "viewer.js", "viewer.css", "pdfjs/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
